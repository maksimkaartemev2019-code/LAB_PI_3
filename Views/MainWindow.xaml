<Window x:Class="LAB_PI_3.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Список задач"
        Width="1080"
        Height="680"
        MinWidth="820"
        MinHeight="520"
        Loaded="Window_Loaded">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Margin="0,0,0,18">
            <StackPanel>
                <TextBlock Text="Список задач"
                           FontSize="30"
                           FontWeight="Bold"
                           Foreground="#15313B" />
                <TextBlock Text="MVVM-приложение для управления личными задачами"
                           Foreground="#526A76"
                           FontSize="14" />
            </StackPanel>

            <Border DockPanel.Dock="Right"
                    Background="#D8EEF2"
                    Padding="14,8"
                    CornerRadius="4"
                    Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}">
                <TextBlock Text="Выполняется операция..."
                           Foreground="#15515F"
                           FontWeight="SemiBold" />
            </Border>
        </DockPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="24" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="0,0,0,12">
                    <TextBlock Text="Фильтр:"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold"
                               Margin="0,0,8,0" />
                    <ComboBox Width="180"
                              ItemsSource="{Binding FilterOptions}"
                              SelectedItem="{Binding SelectedFilter}" />
                </StackPanel>

                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding FilteredTasks}"
                          SelectedItem="{Binding SelectedTodo, Mode=TwoWay}"
                          AutoGenerateColumns="False"
                          SelectionMode="Single">
                    <DataGrid.Columns>
                        <DataGridCheckBoxColumn Header="Выбрать"
                                                Binding="{Binding IsSelectedForDeletion, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                Width="80" />
                        <DataGridTextColumn Header="Название"
                                            Binding="{Binding Title}"
                                            Width="*"
                                            IsReadOnly="True" />
                        <DataGridTextColumn Header="Описание"
                                            Binding="{Binding Description}"
                                            Width="2*"
                                            IsReadOnly="True" />
                        <DataGridTextColumn Header="Статус"
                                            Binding="{Binding StatusText}"
                                            Width="110"
                                            IsReadOnly="True" />
                        <DataGridTextColumn Header="Создана"
                                            Binding="{Binding CreatedAt, StringFormat=dd.MM.yyyy HH:mm}"
                                            Width="140"
                                            IsReadOnly="True" />
                    </DataGrid.Columns>
                </DataGrid>

                <Button Grid.Row="2"
                        Content="Удалить выбранные задачи"
                        Command="{Binding DeleteCheckedCommand}"
                        HorizontalAlignment="Left"
                        Margin="0,12,0,0"
                        Background="#B23A48" />
            </Grid>

            <ScrollViewer Grid.Column="2"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Border Background="White"
                            BorderBrush="#D6E1E8"
                            BorderThickness="1"
                            Padding="18"
                            CornerRadius="6"
                            Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="Новая задача"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="#15313B" />
                            <TextBlock Text="Название" Margin="0,14,0,0" />
                            <TextBox Text="{Binding NewTitle, UpdateSourceTrigger=PropertyChanged}"
                                     MaxLength="100" />
                            <TextBlock Text="Описание" />
                            <TextBox Text="{Binding NewDescription, UpdateSourceTrigger=PropertyChanged}"
                                     MaxLength="500"
                                     AcceptsReturn="True"
                                     Height="90"
                                     TextWrapping="Wrap" />
                            <Button Content="Добавить"
                                    Command="{Binding AddCommand}" />
                        </StackPanel>
                    </Border>

                    <Border Background="White"
                            BorderBrush="#D6E1E8"
                            BorderThickness="1"
                            Padding="18"
                            CornerRadius="6">
                        <StackPanel>
                            <TextBlock Text="Редактирование"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="#15313B" />
                            <TextBlock Text="Выберите задачу в списке"
                                       Foreground="#526A76"
                                       Margin="0,4,0,12" />
                            <TextBlock Text="Название" />
                            <TextBox Text="{Binding EditorTitle, UpdateSourceTrigger=PropertyChanged}"
                                     MaxLength="100" />
                            <TextBlock Text="Описание" />
                            <TextBox Text="{Binding EditorDescription, UpdateSourceTrigger=PropertyChanged}"
                                     MaxLength="500"
                                     AcceptsReturn="True"
                                     Height="90"
                                     TextWrapping="Wrap" />
                            <CheckBox Content="Выполнена"
                                      IsChecked="{Binding EditorIsCompleted}"
                                      Margin="0,4,0,8" />
                            <Button Content="Сохранить изменения"
                                    Command="{Binding SaveSelectedCommand}" />
                            <Button Content="Удалить задачу"
                                    Command="{Binding DeleteSelectedCommand}"
                                    Background="#B23A48" />
                        </StackPanel>
                    </Border>

                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="#B23A48"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               Margin="0,14,0,0" />
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
