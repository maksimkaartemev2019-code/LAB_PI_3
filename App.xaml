<Application x:Class="LAB_PI_3.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="Views/MainWindow.xaml">
    <Application.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <Style TargetType="Window">
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="Background" Value="#F4F7F9" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Margin" Value="0,6,0,0" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Background" Value="#1F7A8C" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="0,4,0,10" />
            <Setter Property="Padding" Value="8" />
            <Setter Property="BorderBrush" Value="#B8C7D1" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="0,4,0,10" />
            <Setter Property="Padding" Value="8" />
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#D6E1E8" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="RowHeaderWidth" Value="0" />
        </Style>
    </Application.Resources>
</Application>
